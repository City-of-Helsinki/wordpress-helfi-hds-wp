    "description": {
      "type": "string",
      "default": ""
    },
    "diagramTitle": {
      "type": "string",
      "default": ""
    },
    "diagramDescription": {
      "type": "string",
      "default": ""
    },
    "url": {
      "type": "string",
      "default": ""
    },
    "assistiveTitle": {
      "type": "string",
      "default": ""
    }
  },
  "render_callback": "hds_wp_render_diagram",
  "style": [ "helsinki-wp-blocks" ]
}
