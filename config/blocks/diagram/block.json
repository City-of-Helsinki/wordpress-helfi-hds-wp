{
  "apiVersion": 3,
  "title": "Helsinki - Diagram",
  "description": "Embed a daigram from the Power BI.",
  "name": "hds-wp/diagram",
  "icon": "chart-area",
  "textdomain": "hds-wp",
  "category": "hds-wp",
  "attributes": {
    "blockId": {
      "type": "string",
      "default": ""
    },
    "title": {
      "type": "string",
      "default": ""
